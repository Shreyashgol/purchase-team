# Shared database used by all SAP agents.
SAP_AGENTS_DATABASE_URL=postgresql://username:password@host:5432/sap_agents_db?sslmode=require

# SAP Business One Service Layer.
SAP_BASE_URL=http://localhost:50000/b1s/v1
SAP_USERNAME=manager
SAP_PASSWORD=password
SAP_COMPANYDB=SBODEMOUS

# JWT settings used by all FastAPI agents.
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=120

# Groq settings used by intent parsers and the Purchase Team router.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# SQL fetch safety timeout.
SQL_QUERY_TIMEOUT=30

# Unified Streamlit/FastAPI target endpoints.
PURCHASE_ORDER_API_URL=http://127.0.0.1:8000/purchase-orders/parse-and-execute
AP_INVOICE_API_URL=http://127.0.0.1:8000/ap-invoices/parse-and-execute
PURCHASE_RETURN_API_URL=http://127.0.0.1:8000/purchase-returns/parse-and-execute
